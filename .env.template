# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
SERVICE_NAME=cronjob
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ENVIRONMENT=local

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=log

# ──────────────────────────────────────────────
# Database Engine
# Supported: postgres | supabase | mysql
# ──────────────────────────────────────────────
DB_ENGINE=postgres

# ──────────────────────────────────────────────
# Database Credentials
# ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
DB_SSLMODE=disable
